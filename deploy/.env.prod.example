# ============================================================================
#  /opt/team-prompts/.env  —  copy to the server, fill in, keep OFF git.
#  Consumed by deploy/docker-compose.prod.yml.
#  ASP.NET maps "__" to nested config keys (Foo__Bar -> Foo:Bar).
#  Generate strong values with:  openssl rand -base64 36 | tr -d '/+='
# ============================================================================

# ---- GHCR image coordinates (lowercase). IMAGE_TAG is overwritten per release
#      by the deploy workflow (commit SHA); "latest" is the manual fallback. -----
GH_REPO=skyp1nus/team-prompts
IMAGE_TAG=latest

# ---- Public origin. The shared Caddy terminates TLS for this domain. -----------
#      Drives Cors__AllowedOrigins (compose interpolation).
App__PublicBaseUrl=https://team-prompts.danielhub.dev

# ---- Postgres (SHARED instance, database "teamprompts", role "teamprompts") -----
#      Host "postgres" is the shared stack's network alias on the "web" network.
#      Password MUST equal the role password created in the shared Postgres
#      (CREATE ROLE teamprompts ... — see deploy/README.md). Hangfire uses this
#      same DB (its own schema); no Redis.
ConnectionStrings__Default=Host=postgres;Port=5432;Database=teamprompts;Username=teamprompts;Password=CHANGE-ME-teamprompts-db-password

# ---- First-run seed admin (created only when no user exists yet) ----------------
Seed__AdminEmail=admin@teamprompts.local
Seed__AdminPassword=CHANGE-ME-strong-admin-password

# ---- OpenRouter base URL. The API KEY is NOT here — it is set write-only via the
#      Settings UI (encrypted at rest with the Data Protection key ring). ---------
OpenRouter__BaseUrl=https://openrouter.ai/api/v1

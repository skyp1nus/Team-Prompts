# =============================================================================
# Team Prompts — environment configuration
# -----------------------------------------------------------------------------
# Copy this file to the repo root as `.env` and fill in real values:
#     cp infra/.env.example .env
# docker compose automatically loads `.env` from the project root.
# =============================================================================

# --- Postgres --------------------------------------------------------------
# Credentials for the `db` (postgres:17) service. The values must match the
# Username/Password/Database used in ConnectionStrings__Default below.
POSTGRES_USER=teamprompts
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=teamprompts

# --- API: database connection ----------------------------------------------
# .NET connection string consumed by the `api` service as
# ConnectionStrings:Default. `Host=db` resolves to the Postgres container on
# the compose network. Keep Username/Password/Database in sync with the
# POSTGRES_* values above.
ConnectionStrings__Default=Host=db;Port=5432;Database=teamprompts;Username=teamprompts;Password=change-me-strong-password

# --- API: seed admin account -----------------------------------------------
# The initial administrator account created on first startup.
Seed__AdminEmail=admin@teamprompts.local
Seed__AdminPassword=Admin123!

# --- API: data protection --------------------------------------------------
# Directory where ASP.NET Core Data Protection keys are persisted. Mounted as
# the `dpkeys` named volume so keys survive container restarts. Leave as /keys.
DataProtection__KeyRingPath=/keys

# --- API: OpenRouter --------------------------------------------------------
# Base URL for the OpenRouter API used for prompt generation.
OpenRouter__BaseUrl=https://openrouter.ai/api/v1
# NOTE: the OpenRouter API key is NOT configured here. It is set at runtime via the
# Settings UI and stored write-only (encrypted via Data Protection) in AppSettings.

# --- API: CORS -------------------------------------------------------------
# Comma-separated list of origins allowed by the API. For local use this is the
# Caddy front door. Add real origins (e.g. https://prompts.example.com) in prod.
Cors__AllowedOrigins=http://localhost

# --- Web (Next.js) ---------------------------------------------------------
# Origin the browser uses to reach the API. Baked into the client bundle at build.
# Leave EMPTY for same origin behind Caddy (the OpenAPI paths already include /api).
# Set to e.g. http://localhost:5258 only when the web is served from a different origin.
NEXT_PUBLIC_API_BASE_URL=
